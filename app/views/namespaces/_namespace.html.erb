<%= link_to project_namespace_path(project, namespace),
      id: dom_id(namespace),
      class: "namespace-item flex items-center justify-between px-[18px] py-[15px] no-underline border-b border-line-3 last:border-b-0 hover:bg-surface-2 transition-colors" do %>
  <span class="flex items-center gap-[11px] min-w-0">
    <%= mi "folder", size: 18, css: "text-faint" %>
    <span class="font-mono text-[14px] font-semibold text-ink truncate"><%= namespace.name %></span>
  </span>
  <span class="flex items-center gap-[16px]">
    <span class="font-mono text-[12px] text-ink-3"><span class="text-ink font-semibold"><%= namespace.translation_keys_count %></span> keys</span>
    <%= mi "chevron_right", size: 20, css: "text-faint-2" %>
  </span>
<% end %>
