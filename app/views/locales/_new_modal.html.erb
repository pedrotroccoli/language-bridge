<%# Shared "New locale" dialog — multi-select combobox over Locale::CATALOG.
    Render inside a `data-controller="modal"` scope. %>
<dialog class="modal w-[440px]" data-modal-target="dialog" data-action="click->modal#closeOnBackdrop" aria-labelledby="new-locale-title">
  <div class="flex items-center justify-between px-[22px] py-[18px] border-b border-line-2">
    <h3 id="new-locale-title" class="m-0 text-[16px] font-semibold text-ink">New locale</h3>
    <button type="button" class="text-mut-2 hover:text-ink" data-action="click->modal#close" aria-label="Close"><%= mi "close", size: 18 %></button>
  </div>

  <% existing = project.locales.pluck(:code).compact.map(&:downcase) %>
  <%= form_with url: project_locales_path(project), method: :post, local: true, html: { class: "p-[22px] flex flex-col gap-4" } do |form| %>
    <div class="flex flex-col gap-[7px]"
         data-controller="combobox"
         data-combobox-multiple-value="true"
         data-combobox-name-value="locale[codes][]"
         data-combobox-pattern-value="^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$">
      <label class="text-[12.5px] font-medium text-ink-2">Languages</label>
      <div class="relative z-30">
        <div class="flex flex-wrap items-center gap-[6px] min-h-[42px] px-[10px] py-[6px] border border-line rounded-[9px] focus-within:border-accent focus-within:shadow-[0_0_0_3px_var(--color-accent-soft)] transition cursor-text"
             data-action="click->combobox#open">
          <span data-combobox-target="chips" class="contents"></span>
          <span class="flex items-center gap-[8px] flex-1 min-w-[140px]">
            <%= mi "search", size: 18, css: "text-mut-2" %>
            <input type="text" placeholder="Search languages…" autocomplete="off" autocapitalize="none" spellcheck="false"
                   data-combobox-target="input"
                   data-action="input->combobox#filter focus->combobox#open keydown.enter->combobox#enter"
                   class="!border-0 !p-0 !shadow-none flex-1 bg-transparent text-[14px] focus:!ring-0">
          </span>
        </div>
        <ul data-combobox-target="list" class="hidden absolute left-0 right-0 top-[calc(100%+6px)] z-30 max-h-[260px] overflow-y-auto bg-surface border border-line rounded-[9px] shadow-[0_12px_32px_-12px_rgba(15,23,42,0.28)] p-[5px]">
          <% Locale::CATALOG.each do |code, name| %>
            <% next if existing.include?(code.downcase) %>
            <li data-combobox-target="option" data-code="<%= code %>" data-label="<%= "#{name} #{code}" %>" data-display="<%= name %>"
                data-action="click->combobox#select"
                class="flex items-center justify-between gap-3 px-[10px] py-2 rounded-[6px] cursor-pointer hover:bg-surface-2">
              <span class="text-[13px] text-ink"><%= name %></span>
              <span class="font-mono text-[12px] text-mut-2"><%= code %></span>
            </li>
          <% end %>
          <li data-combobox-target="empty" hidden class="px-[10px] py-3 text-[13px] text-mut text-center">No match — press Enter to add a custom tag</li>
        </ul>
      </div>
      <small class="text-[12px] text-mut-2">Pick one or more, or type a custom IETF tag and press Enter.</small>
    </div>
    <div class="flex justify-end gap-[9px] pt-1">
      <button type="button" class="btn-secondary" data-action="click->modal#close">Cancel</button>
      <%= form.submit "Add languages", class: "btn" %>
    </div>
  <% end %>
</dialog>
