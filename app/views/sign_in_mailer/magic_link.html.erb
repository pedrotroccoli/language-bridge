<%# Table-based + inline styles for email-client compatibility. %>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0;padding:0;background-color:#f8fafc;">
  <tr>
    <td align="center" style="padding:40px 16px;">
      <table role="presentation" width="440" cellpadding="0" cellspacing="0" border="0" style="width:440px;max-width:100%;background-color:#ffffff;border:1px solid #e2e8f0;border-radius:12px;">

        <%# ---- header: logo, hairline under it ---- %>
        <tr>
          <td style="padding:30px 36px 22px;border-bottom:1px solid #f1f5f9;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td valign="middle" style="padding-right:10px;">
                  <img src="<%= @logo %>" width="30" height="30" alt="Language Bridge" style="display:block;width:30px;height:30px;border-radius:7px;">
                </td>
                <td valign="middle" style="font-family:'Figtree','Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:15px;font-weight:600;letter-spacing:-0.01em;color:#0f172a;">Language&nbsp;Bridge</td>
              </tr>
            </table>
          </td>
        </tr>

        <%# ---- body ---- %>
        <tr>
          <td style="padding:30px 36px 34px;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
            <h1 style="margin:0 0 10px;font-family:'Figtree','Inter',sans-serif;font-size:19px;font-weight:600;letter-spacing:-0.01em;color:#0f172a;">Sign in to your account</h1>
            <p style="margin:0 0 24px;font-size:14px;line-height:1.6;color:#475569;">Use the button below to sign in. The link expires in 15 minutes and can be used once.</p>

            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="border-radius:6px;background-color:#0f172a;">
                  <a href="<%= @url %>" style="display:inline-block;padding:12px 22px;font-size:14px;font-weight:500;color:#ffffff;text-decoration:none;border-radius:6px;">Sign in</a>
                </td>
              </tr>
            </table>

            <p style="margin:16px 0 0;font-size:12.5px;color:#64748b;">Or paste this link into your browser:<br>
              <a href="<%= @url %>" style="color:#1d4ed8;text-decoration:none;word-break:break-all;font-family:'JetBrains Mono',ui-monospace,SFMono-Regular,Menlo,monospace;font-size:11.5px;"><%= @url %></a>
            </p>

            <%# ---- security notice (platform amber banner tokens) ---- %>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:24px;">
              <tr>
                <td style="background-color:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:12px 14px;">
                  <p style="margin:0;font-size:12.5px;line-height:1.55;color:#92400e;">Didn't request this? You can safely ignore this email — no one can sign in without the link above.</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <%# ---- footer ---- %>
        <tr>
          <td style="padding:16px 36px 24px;border-top:1px solid #f1f5f9;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
            <p style="margin:0;font-size:11.5px;color:#94a3b8;">Language Bridge · automated message, please do not reply.</p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
