<% cache [ project, current_user, coverage ] do %>
  <article id="<%= dom_id(project) %>"
           class="project-card border border-line rounded-[9px] transition-colors hover:border-accent"
           data-search-target="card"
           data-searchable-text="<%= "#{project.name} #{project.slug}" %>">
  <%= link_to project_path(project), class: "block p-[18px] no-underline" do %>
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <div class="text-[15px] font-semibold text-ink -tracking-[0.01em] truncate"><%= project.name %></div>
        <div class="font-mono text-[12px] text-faint mt-1"><%= project.slug %></div>
      </div>
      <span class="font-mono text-[11px] text-mut-2 whitespace-nowrap shrink-0"><%= time_ago_in_words(project.updated_at) %> ago</span>
    </div>

    <div class="flex gap-[18px] mt-4 font-mono text-[12px] text-ink-3">
      <span class="inline-flex items-center gap-[5px]"><%= mi "language", size: 15, css: "text-faint" %><span><span class="text-ink font-semibold"><%= project.locales_count %></span> locales</span></span>
      <span class="inline-flex items-center gap-[5px]"><%= mi "folder", size: 15, css: "text-faint" %><span><span class="text-ink font-semibold"><%= project.namespaces_count %></span> ns</span></span>
      <span class="inline-flex items-center gap-[5px]"><%= mi "translate", size: 15, css: "text-faint" %><span><span class="text-ink font-semibold"><%= project.translation_keys_count %></span> keys</span></span>
    </div>

    <div class="mt-4 flex items-center gap-[11px]">
      <div class="flex-1 flex gap-[2px]" role="progressbar" aria-valuenow="<%= coverage %>" aria-valuemin="0" aria-valuemax="100" aria-label="Translation coverage">
        <% progress_segments(coverage).each do |on| %>
          <div class="flex-1 h-1 rounded-[1px] <%= on ? "bg-ink" : "bg-line-2" %>" aria-hidden="true"></div>
        <% end %>
      </div>
      <span class="font-mono text-[12px] text-ink font-semibold"><%= coverage %>%</span>
    </div>
  <% end %>
  </article>
<% end %>
