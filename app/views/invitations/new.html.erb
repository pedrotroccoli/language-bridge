<% content_for :title, "Invite a teammate" %>

<div class="max-w-[460px] mx-auto mt-8">
  <h1 class="m-0 text-[20px] font-semibold -tracking-[0.02em] text-ink">Invite a teammate</h1>
  <p class="mt-[6px] mb-6 text-[13.5px] text-mut">They'll get an email with a one-time accept link.</p>

  <%= form_with model: @invitation, local: true, html: { class: "border border-line rounded-[11px] p-[22px] flex flex-col gap-4" } do |form| %>
    <% if @invitation.errors.any? %>
      <ul class="text-[13px] text-danger-ink bg-danger-soft border border-danger-border rounded-[9px] px-4 py-3 list-disc list-inside">
        <% @invitation.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    <% end %>

    <div class="flex flex-col gap-[7px]">
      <%= form.label :email, class: "text-[12.5px] font-medium text-ink-2" %>
      <%= form.email_field :email, required: true, autofocus: true, placeholder: "teammate@company.com", class: "text-[14px]" %>
    </div>

    <div class="flex flex-col gap-[7px]">
      <%= form.label :role, class: "text-[12.5px] font-medium text-ink-2" %>
      <%= form.select :role, User::ROLES.map { |r| [ r.titleize, r ] }, {}, class: "text-[14px]" %>
    </div>

    <div class="flex justify-end gap-[9px] pt-1">
      <%= link_to "Cancel", invitations_path, class: "btn-secondary" %>
      <%= form.submit "Send invitation", class: "btn" %>
    </div>
  <% end %>
</div>
