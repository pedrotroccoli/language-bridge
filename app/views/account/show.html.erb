<% content_for :title, "Account" %>

<div class="max-w-[720px]">
  <h1 class="m-0 mb-[18px] text-[18px] font-semibold -tracking-[0.01em] text-ink">Account</h1>

  <%# ---- Profile ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-center gap-[9px] text-[16px] font-semibold text-ink mb-4"><%= mi "person", size: 19, css: "text-ink-3" %>Profile</div>

    <%= form_with model: current_user, url: account_path, method: :patch, html: { multipart: true, class: "flex flex-col gap-4" } do |form| %>
      <% if current_user.errors.any? %>
        <ul class="text-[13px] text-danger-ink bg-danger-soft border border-danger-border rounded-[9px] px-4 py-3 list-disc list-inside">
          <% current_user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      <% end %>

      <div class="flex items-center gap-4">
        <%= avatar_for(current_user, px: 56, text_class: "text-[20px]", bg_class: "bg-accent-soft text-accent") %>
        <div class="min-w-0 flex-1">
          <%= form.label :avatar, "Photo", class: "block text-[12.5px] font-medium text-ink-2 mb-[6px]" %>
          <%= form.file_field :avatar, accept: "image/png,image/jpeg,image/gif,image/webp", class: "text-[13px]" %>
          <div class="text-[12px] text-mut mt-[5px]">PNG, JPEG, GIF, or WebP · 2 MB max.</div>
        </div>
      </div>

      <div class="flex flex-col gap-[7px] max-w-[360px]">
        <%= form.label :name, "Display name", class: "text-[12.5px] font-medium text-ink-2" %>
        <%= form.text_field :name, placeholder: current_user.email.split("@").first, class: "text-[14px]" %>
      </div>

      <div class="flex items-center gap-[8px]">
        <span class="text-[12px] text-mut capitalize border border-line rounded-full px-[10px] py-[2px]"><%= current_user.role %></span>
        <span class="text-[12px] text-mut">member since <%= current_user.created_at.strftime("%b %Y") %></span>
      </div>

      <div class="flex justify-end">
        <%= loading_submit form, "Save profile" %>
      </div>
    <% end %>

    <p class="text-[12.5px] text-mut mt-[16px] mb-0">Sign-in is passwordless — a one-time link is emailed to <span class="font-mono text-ink-2"><%= current_user.email %></span>. To change your email, ask an admin to re-invite you.</p>
  </div>

  <%# ---- Personal access token ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-center gap-[9px] text-[16px] font-semibold text-ink mb-1"><%= mi "key", size: 19, css: "text-ink-3" %>Personal access token</div>
    <div class="text-[13px] text-mut mb-4">A bearer token for the personal API and CLI, scoped to the projects you can access. The raw value is shown once — store it securely.</div>

    <% if flash[:pat_created].present? %>
      <div class="mb-4 border border-accent rounded-[9px] bg-accent-soft px-4 py-3">
        <div class="text-[12.5px] font-medium text-ink-2 mb-[6px]">New token (copy now — it won't be shown again):</div>
        <code class="block font-mono text-[12.5px] text-ink break-all"><%= flash[:pat_created] %></code>
      </div>
    <% end %>

    <% if (pat = current_user.personal_access_token) %>
      <div class="flex items-center gap-3 flex-wrap border border-line rounded-[9px] px-4 py-[12px]">
        <%= mi "key", size: 18, css: "text-faint" %>
        <code class="font-mono text-[13px] text-ink-2"><%= pat.masked %></code>
        <span class="text-[12px] text-mut ml-auto"><%= pat.last_used_at ? "used #{time_ago_in_words(pat.last_used_at)} ago" : "never used" %></span>
        <%= button_to "Regenerate", account_personal_access_token_path, method: :post, class: "btn-secondary",
              form_class: "inline", data: { turbo_confirm: "Regenerate your token? The current one stops working immediately." } %>
        <%= button_to "Revoke", account_personal_access_token_path, method: :delete, class: "btn-secondary btn-danger",
              form_class: "inline", data: { turbo_confirm: "Revoke your personal access token?" } %>
      </div>
    <% else %>
      <%= button_to "Generate token", account_personal_access_token_path, method: :post, class: "btn" %>
    <% end %>
  </div>

  <%# ---- Sessions ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5">
    <div class="flex items-center justify-between gap-4 mb-4">
      <div class="flex items-center gap-[9px] text-[16px] font-semibold text-ink"><%= mi "devices", size: 19, css: "text-ink-3" %>Active sessions</div>
      <% if @sessions.size > 1 %>
        <%= button_to "Sign out other sessions", account_sessions_path, method: :delete, class: "btn-secondary",
              data: { turbo_confirm: "Sign out of all sessions except this one?" } %>
      <% end %>
    </div>
    <div class="border border-line rounded-[9px] overflow-hidden">
      <% @sessions.each do |session| %>
        <div class="flex items-center gap-3 px-4 py-[11px] border-b border-line-3 last:border-b-0">
          <%= mi "computer", size: 18, css: "text-faint" %>
          <div class="min-w-0 flex-1">
            <div class="text-[13px] text-ink truncate"><%= session.user_agent.presence || "Unknown device" %></div>
            <div class="font-mono text-[11.5px] text-mut mt-[2px]"><%= session.ip_address.presence || "—" %> · <%= time_ago_in_words(session.created_at) %> ago</div>
          </div>
          <% if session.id == Current.session.id %>
            <span class="font-mono text-[10px] text-accent bg-accent-soft rounded-[4px] px-[7px] py-px flex-none">THIS DEVICE</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
