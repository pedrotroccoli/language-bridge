<%# Storage-connection modal — create + edit. Driven by connection_form_controller. %>
<dialog class="modal w-[560px]" data-connection-form-target="dialog" data-action="click->connection-form#closeOnBackdrop">
  <%= form_with url: storage_connections_path, method: :post, data: { "connection-form-target": "form", action: "input->connection-form#invalidate" }, html: { class: "flex flex-col max-h-[calc(100vh-48px)]" } do %>
    <div class="flex items-center justify-between px-[22px] py-[18px] border-b border-line">
      <h3 class="m-0 text-[16px] font-semibold text-ink" data-connection-form-target="title">New connection</h3>
      <button type="button" class="text-mut hover:text-ink text-[16px] leading-none" data-action="connection-form#close" aria-label="Close">✕</button>
    </div>

    <div class="px-[22px] py-[22px] flex flex-col gap-4 overflow-y-auto">
      <div>
        <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]">Connection name</label>
        <%= text_field_tag "storage_connection[name]", nil, placeholder: "Production", spellcheck: "false", required: true, class: "w-full text-[14px]" %>
      </div>

      <div>
        <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]">Service</label>
        <%= hidden_field_tag "storage_connection[service]", "local", data: { "connection-form-target": "service" } %>
        <div class="inline-flex items-center gap-[3px] p-[3px] bg-surface-2 rounded-[9px]">
          <% [ %w[local Local], %w[s3 S3], %w[gcs GCS], %w[azure Azure] ].each do |val, label| %>
            <span data-connection-form-target="segment" data-service="<%= val %>" data-action="click->connection-form#pickService"
                  class="flex items-center h-[30px] px-[14px] rounded-[7px] text-[12px] cursor-pointer text-mut"><%= label %></span>
          <% end %>
        </div>
      </div>

      <div data-connection-form-target="cloudFields" class="flex flex-col gap-4" hidden>
        <label class="flex items-start gap-[10px] cursor-pointer p-[11px] border border-line rounded-[9px]">
          <%= check_box_tag "storage_connection[inherit_credentials]", "1", false, data: { "connection-form-target": "inherit", action: "change->connection-form#toggleInherit" }, class: "w-[16px] h-[16px] mt-[1px]" %>
          <span>
            <span class="block text-[13px] text-ink font-medium">Inherit credentials from environment</span>
            <span class="block text-[12px] text-mut mt-[2px]">Use the instance / pod IAM role (EC2, ECS, EKS, GKE…). No keys are stored.</span>
          </span>
        </label>

        <div class="grid grid-cols-[1fr_200px] gap-4">
          <div>
            <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]" data-connection-form-target="bucketLabel">Bucket</label>
            <%= text_field_tag "storage_connection[bucket]", nil, placeholder: "my-bucket-prod", spellcheck: "false", data: { "connection-form-target": "bucket" }, class: "w-full font-mono text-[13px]" %>
          </div>
          <div data-connection-form-target="regionField">
            <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]" data-connection-form-target="regionLabel">Region</label>
            <%= select_tag "storage_connection[region]", options_for_select(aws_region_options, "us-east-1"), data: { "connection-form-target": "region" }, class: "w-full text-[13px]" %>
          </div>
        </div>

        <div>
          <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]">Path prefix <span class="text-mut font-normal">(optional)</span></label>
          <%= text_field_tag "storage_connection[prefix]", nil, placeholder: "language-bridge-poc", spellcheck: "false", class: "w-full font-mono text-[13px]" %>
          <p class="mt-[6px] text-[12px] text-mut">Base path inside the bucket for all objects (backups, uploads, the test probe). Matches a path-scoped IAM policy.</p>
        </div>

        <div data-connection-form-target="endpointField">
          <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]">Endpoint <span class="text-mut font-normal">(optional — S3-compatible)</span></label>
          <%= text_field_tag "storage_connection[endpoint]", nil, placeholder: "https://…", spellcheck: "false", class: "w-full font-mono text-[13px]" %>
        </div>

        <div data-connection-form-target="credFields" class="flex flex-col gap-4">
          <div>
            <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]" data-connection-form-target="keyLabel">Access key ID</label>
            <%= text_field_tag "storage_connection[access_key_id]", nil, spellcheck: "false", class: "w-full font-mono text-[13px]" %>
          </div>
          <div>
            <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]" data-connection-form-target="secretLabel">Secret access key</label>
            <div class="relative">
              <%= password_field_tag "storage_connection[secret_access_key]", nil, placeholder: "••••••••••••", spellcheck: "false", autocomplete: "off",
                    data: { "connection-form-target": "secret", "1p-ignore": "", bwignore: "", lpignore: "true" }, class: "w-full font-mono text-[13px] pr-[42px]" %>
              <button type="button" class="absolute top-0 right-0 h-full w-[40px] flex items-center justify-center text-faint hover:text-ink" data-action="connection-form#toggleSecret" aria-label="Toggle secret visibility">
                <span class="material-symbols-outlined" style="font-size:18px" data-connection-form-target="secretToggleIcon">visibility</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between gap-3 px-[22px] py-4 border-t border-line bg-surface-2 rounded-b-[13px]">
      <span class="text-[12.5px]" data-connection-form-target="testResult"></span>
      <div class="flex items-center gap-[9px]">
        <button type="button" class="btn-secondary" data-action="connection-form#test"><%= mi "bolt", size: 16, css: "mr-[5px]" %>Test connection</button>
        <%= submit_tag "Save connection", data: { "connection-form-target": "submit" }, class: "btn" %>
      </div>
    </div>
  <% end %>
</dialog>
