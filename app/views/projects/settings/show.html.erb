<% content_for :title, "Settings · #{@project.name}" %>
<% content_for :main_class, "flex-1 w-full flex flex-col min-h-0" %>

<%= render "projects/tabs", project: @project, active: :settings %>

<div class="mx-auto w-full max-w-[1320px] px-6 py-7">
  <div>
  <h2 class="m-0 mb-[18px] text-[17px] font-semibold text-ink">Settings</h2>

  <%# ---- General ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-center gap-[9px] text-[15px] font-semibold text-ink"><%= mi "tune", size: 19, css: "text-ink-3" %>General</div>
    <div class="text-[13px] text-mut mt-[3px] mb-[18px]">Project name and slug.</div>

    <%= form_with model: @project, local: true do |form| %>
      <% if @project.errors.any? %>
        <ul class="mb-4 text-[13px] text-danger-ink bg-danger-soft border border-danger-border rounded-[9px] px-4 py-3 list-disc list-inside">
          <% @project.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      <% end %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-[7px]">
          <%= form.label :name, "Name", class: "text-[12.5px] font-medium text-ink-2" %>
          <%= form.text_field :name, required: true, class: "text-[14px]" %>
        </div>
        <div class="flex flex-col gap-[7px]">
          <label class="text-[12.5px] font-medium text-ink-2">Slug</label>
          <div class="h-[42px] flex items-center px-[13px] border border-line rounded-[9px] font-mono text-[13px] text-ink-3 bg-surface-2"><%= @project.slug %></div>
        </div>
      </div>
      <div class="flex justify-end mt-[18px]">
        <%= loading_submit form, "Save changes" %>
      </div>
    <% end %>
  </div>

  <%# ---- Locales ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-center gap-[9px] text-[15px] font-semibold text-ink"><%= mi "language", size: 19, css: "text-ink-3" %>Locales</div>
    <div class="text-[13px] text-mut mt-[3px] mb-4">Rename or remove the languages this project translates into. Add new ones from the project overview.</div>
    <% if @locales.any? %>
      <div class="border border-line rounded-[9px] overflow-hidden">
        <% @locales.each do |locale| %>
          <div class="flex items-center gap-2 px-4 py-[10px] border-b border-line-3 last:border-b-0">
            <%= form_with model: [ @project, locale ], method: :patch, local: true, html: { class: "flex items-center gap-2 flex-1 min-w-0" } do |f| %>
              <%= mi "language", size: 18, css: "text-faint" %>
              <%= f.text_field :code, required: true, "aria-label": "Locale code",
                    pattern: "[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*", autocomplete: "off", autocapitalize: "none", spellcheck: "false",
                    class: "font-mono text-[13px] max-w-[180px]" %>
              <% if locale_name(locale.code) %><span class="text-[13px] text-ink-3 truncate min-w-0"><%= locale_name(locale.code) %></span><% end %>
              <%= f.submit "Save", class: "btn-secondary ml-auto" %>
            <% end %>
            <%= button_to project_locale_path(@project, locale), method: :delete, class: "btn-secondary btn-danger", form_class: "inline",
                  "aria-label": "Delete locale #{locale.code}",
                  data: { turbo_confirm: "Delete locale \"#{locale.code}\"? All its translations will be removed." } do %>
              <%= mi "delete", size: 16 %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-[13px] text-mut">No locales yet.</p>
    <% end %>
  </div>

  <%# ---- Namespaces ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-center gap-[9px] text-[15px] font-semibold text-ink"><%= mi "folder", size: 19, css: "text-ink-3" %>Namespaces</div>
    <div class="text-[13px] text-mut mt-[3px] mb-4">Rename or remove namespaces. Add new ones from the project overview.</div>
    <% if @namespaces.any? %>
      <div class="border border-line rounded-[9px] overflow-hidden">
        <% @namespaces.each do |namespace| %>
          <div class="flex items-center gap-2 px-4 py-[10px] border-b border-line-3 last:border-b-0">
            <%= form_with model: [ @project, namespace ], method: :patch, local: true, data: { controller: "slug-input" }, html: { class: "flex items-center gap-2 flex-1 min-w-0" } do |f| %>
              <%= mi "folder", size: 18, css: "text-faint" %>
              <%= f.text_field :name, required: true, "aria-label": "Namespace name",
                    pattern: "[a-z0-9][a-z0-9_\\-\\.]*", autocomplete: "off", autocapitalize: "none", spellcheck: "false",
                    class: "font-mono text-[13px] max-w-[260px]", data: { action: "beforeinput->slug-input#prevent input->slug-input#sanitize" } %>
              <%= f.submit "Save", class: "btn-secondary" %>
            <% end %>
            <%= button_to project_namespace_path(@project, namespace), method: :delete, class: "btn-secondary btn-danger", form_class: "inline",
                  "aria-label": "Delete namespace #{namespace.name}",
                  data: { turbo_confirm: "Delete namespace \"#{namespace.name}\"? This cannot be undone." } do %>
              <%= mi "delete", size: 16 %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-[13px] text-mut">No namespaces yet.</p>
    <% end %>
  </div>

  <%# ---- Uploads ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4"
       data-controller="upload-settings">
    <div class="flex items-center gap-[9px] text-[15px] font-semibold text-ink"><%= mi "cloud_upload", size: 19, css: "text-ink-3" %>Uploads</div>
    <div class="text-[13px] text-mut mt-[3px] mb-[18px]">Per-project upload rules. The storage connection is managed in workspace settings.</div>

    <% if @storage_connections.any?(&:cloud?) %>
    <%= form_with model: @project, url: project_upload_settings_path(@project), method: :patch, local: true do |form| %>
      <div class="flex items-end justify-between gap-3 mb-[7px]">
        <label class="text-[12.5px] font-medium text-ink-2">Storage connection</label>
        <%= link_to workspace_path, class: "flex items-center gap-[5px] text-[12.5px] text-accent font-medium hover:underline whitespace-nowrap" do %>
          <%= mi "tune", size: 16 %>Manage connections
        <% end %>
      </div>
      <%= form.select :storage_connection_id,
            @storage_connections.map { |c| [ "#{c.name} (#{c.service_label})", c.id, { "data-bucket": c.bucket } ] },
            { include_blank: "Workspace default#{StorageConnection.default ? " — #{StorageConnection.default.name}" : ""}" },
            data: { "upload-settings-target": "connection", action: "upload-settings#syncBucket" }, class: "text-[14px] mb-[18px]" %>

      <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]">Upload path</label>
      <div class="flex items-stretch border border-line rounded-[9px] overflow-hidden bg-surface mb-[18px]">
        <span class="flex items-center gap-[6px] px-[11px] pl-[13px] bg-surface-2 border-r border-line font-mono text-[13px] text-faint whitespace-nowrap"
              data-upload-settings-target="bucketPrefix" <%= "hidden" if @project.effective_storage_connection&.bucket.blank? %>><%= "#{@project.effective_storage_connection&.bucket}/" if @project.effective_storage_connection&.bucket.present? %></span>
        <%= form.text_field :upload_path, spellcheck: "false", placeholder: "uploads/", class: "flex-1 min-w-0 font-mono text-[13px] border-0 rounded-none" %>
      </div>

      <div class="flex items-center justify-between gap-6 mb-4">
        <div>
          <div class="text-[14px] font-medium text-ink">Override workspace defaults</div>
          <div class="text-[12px] text-mut mt-[2px]">Use project-specific formats and size limit instead of the workspace defaults.</div>
        </div>
        <label class="cursor-pointer flex-none">
          <%= form.check_box :upload_override, data: { "upload-settings-target": "override", action: "upload-settings#toggleOverride" }, class: "w-[16px] h-[16px]" %>
        </label>
      </div>

      <div data-upload-settings-target="inheritSummary" class="border border-line rounded-[9px] bg-surface-2 px-[15px] py-[14px]">
        <div class="flex items-center justify-between mb-[11px]"><span class="text-[12px] text-mut">Max file size</span><span class="font-mono text-[12px] text-ink"><%= number_to_human_size(Setting.current.upload_max_bytes) %></span></div>
        <div class="flex items-start justify-between gap-4"><span class="text-[12px] text-mut leading-[26px]">Allowed formats</span>
          <div class="flex flex-wrap gap-[6px] justify-end"><% Setting.current.upload_allowed_formats.each do |f| %><span class="font-mono text-[11px] text-ink-2 bg-surface border border-line rounded-[6px] px-2 py-[3px]"><%= f.upcase %></span><% end %></div>
        </div>
      </div>

      <div data-upload-settings-target="overrideFields" hidden>
        <div class="max-w-[220px] mb-[18px]">
          <%= form.label :upload_max_bytes, "Max file size", class: "block text-[12.5px] font-medium text-ink-2 mb-[7px]" %>
          <%= form.select :upload_max_bytes, upload_size_options, { include_blank: "Workspace default" }, class: "text-[14px]" %>
        </div>
        <label class="block text-[12.5px] font-medium text-ink-2 mb-[7px]">Allowed import formats</label>
        <%= render "shared/format_checkboxes", form: form, field: :upload_allowed_formats, selected: (@project.upload_allowed_formats || Setting.current.upload_allowed_formats) %>
      </div>

      <div class="flex justify-end mt-5">
        <%= loading_submit form, "Save changes" %>
      </div>
    <% end %>
    <% else %>
      <div class="border border-dashed border-line rounded-[9px] px-[26px] py-9 flex flex-col items-center text-center bg-surface-2">
        <div class="w-[44px] h-[44px] border-[1.5px] border-line rounded-[11px] flex items-center justify-center text-faint bg-surface mb-[14px]"><%= mi "cloud_off", size: 22 %></div>
        <h3 class="m-0 text-[15px] font-semibold text-ink">Uploads need a cloud connection</h3>
        <p class="mt-[7px] mb-4 text-[13px] text-mut max-w-[360px] leading-[1.5]">Connect an S3, GCS or Azure bucket in workspace settings to enable file uploads for this project.</p>
        <%= link_to workspace_path, class: "btn" do %><%= mi "corporate_fare", size: 16, css: "mr-[6px]" %>Set up storage connection<% end %>
      </div>
    <% end %>
  </div>

  <%# ---- Delivery / CDN ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="flex items-center gap-[9px] text-[15px] font-semibold text-ink"><%= mi "cloud", size: 19, css: "text-ink-3" %>Public delivery</div>
        <div class="text-[13px] text-mut mt-[3px] mb-4">Published translations are served as JSON from the CDN endpoint (i18next <code class="font-mono">loadPath</code> convention).</div>
      </div>
      <%= loading_button_to "Sync all to storage", project_delivery_sync_path(@project), method: :post, icon: "sync", class: "btn-secondary flex-none",
            data: { turbo_confirm: "Re-materialize every published namespace/locale to #{@project.effective_storage_connection&.name || "local storage"}?" } %>
    </div>
    <div class="bg-[#0d0d0d] rounded-[9px] px-[18px] py-4 font-mono text-[12.5px] leading-[2] text-[#e4e4e4] overflow-x-auto">
      <div><span class="text-[#5e5e5e]">GET</span> <%= request.base_url %>/cdn/<span class="text-[#6bd08f]"><%= @project.slug %></span>/{locale}/{namespace}</div>
      <% sample_locale = @project.locales.alphabetically.first&.code || "en" %>
      <% sample_ns = @project.namespaces.alphabetically.first&.name || "common" %>
      <div><span class="text-[#5e5e5e]">GET</span> <%= request.base_url %>/cdn/<span class="text-[#6bd08f]"><%= @project.slug %></span>/<%= sample_locale %>/<%= sample_ns %></div>
    </div>

    <%# ---- Storage path template (issue #77): deterministic Active Storage key ---- %>
    <%
      ns_names  = @namespaces.any? ? @namespaces.first(2).map(&:name) : [ "common" ]
      loc_codes = @locales.any? ? @locales.first(2).map(&:code) : [ "en" ]
      delivery_samples = ns_names.product(loc_codes).first(3).map { |n, l| { project_slug: @project.slug, namespace: n, locale: l } }
    %>
    <%= form_with model: @project, local: true,
          data: { controller: "delivery-preview", "delivery-preview-samples-value": delivery_samples.to_json } do |form| %>
      <% if @project.errors[:delivery_path_template].any? %>
        <ul class="mt-4 mb-2 text-[13px] text-danger-ink bg-danger-soft border border-danger-border rounded-[9px] px-4 py-3 list-disc list-inside">
          <% @project.errors[:delivery_path_template].each do |msg| %><li>Path template <%= msg %></li><% end %>
        </ul>
      <% end %>

      <label class="block text-[12.5px] font-medium text-ink-2 mt-[18px] mb-[7px]">Storage path template</label>
      <%= form.text_field :delivery_path_template,
            data: { "delivery-preview-target": "input", action: "input->delivery-preview#render" },
            autocomplete: "off", autocapitalize: "none", spellcheck: "false", class: "font-mono text-[13px]" %>
      <div class="text-[12px] text-mut mt-[7px]">Object key for materialized artifacts in your Active Storage bucket — point a CDN origin at it.
        Tokens: <code class="font-mono">{project_slug}</code> <code class="font-mono">{namespace}</code> <code class="font-mono">{locale}</code>
        (must include <code class="font-mono">{namespace}</code> and <code class="font-mono">{locale}</code>).</div>

      <div class="mt-[12px] mb-[6px] text-[12px] font-medium text-ink-2">Resulting paths</div>
      <div data-delivery-preview-target="output" class="border border-line rounded-[9px] bg-surface-2 px-[14px] py-[10px] flex flex-col gap-[3px]"></div>

      <div class="flex justify-end mt-[14px]">
        <%= loading_submit form, "Save path template" %>
      </div>
    <% end %>
  </div>

  <%# ---- API tokens ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-center gap-[9px] text-[15px] font-semibold text-ink"><%= mi "key", size: 19, css: "text-ink-3" %>API tokens</div>
    <div class="text-[13px] text-mut mt-[3px] mb-4">Bearer tokens for client SDKs calling the saveMissing API. The raw token is shown once at creation — store it securely.</div>

    <% if flash[:token_created].present? %>
      <div class="mb-4 border border-accent rounded-[9px] bg-accent-soft px-4 py-3">
        <div class="text-[12.5px] font-medium text-ink-2 mb-[6px]">New token (copy now — it won't be shown again):</div>
        <code class="block font-mono text-[12.5px] text-ink break-all"><%= flash[:token_created] %></code>
      </div>
    <% end %>

    <% if @api_tokens.any? %>
      <div class="border border-line rounded-[9px] overflow-hidden mb-4">
        <% @api_tokens.each do |token| %>
          <div class="flex items-center gap-2 px-4 py-[10px] border-b border-line-3 last:border-b-0">
            <%= mi "key", size: 18, css: "text-faint" %>
            <span class="text-[13px] text-ink truncate min-w-0"><%= token.name %></span>
            <span class="font-mono text-[11px] text-ink-3 bg-surface-2 rounded px-[6px] py-px"><%= token.scope %></span>
            <span class="text-[12px] text-mut ml-auto"><%= token.last_used_at ? "used #{time_ago_in_words(token.last_used_at)} ago" : "never used" %></span>
            <%= button_to project_api_token_path(@project, token), method: :delete, class: "btn-secondary btn-danger", form_class: "inline",
                  "aria-label": "Revoke token #{token.name}",
                  data: { turbo_confirm: "Revoke token \"#{token.name}\"? Clients using it will stop working." } do %>
              <%= mi "delete", size: 16 %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-[13px] text-mut mb-4">No tokens yet.</p>
    <% end %>

    <%= form_with url: project_api_tokens_path(@project), method: :post, local: true, html: { class: "flex items-end gap-3 flex-wrap" } do %>
      <div class="flex flex-col gap-[7px]">
        <label class="text-[12.5px] font-medium text-ink-2">Name</label>
        <%= text_field_tag "api_token[name]", nil, placeholder: "e.g. Web client", required: true, class: "text-[14px]" %>
      </div>
      <div class="flex flex-col gap-[7px]">
        <label class="text-[12.5px] font-medium text-ink-2">Scope</label>
        <%= select_tag "api_token[scope]", options_for_select(ApiToken::SCOPES, "save_missing"), class: "text-[14px]" %>
      </div>
      <%= submit_tag "Create token", class: "btn" %>
    <% end %>
  </div>

  <%# ---- Rate limit override ---- %>
  <div class="border border-line rounded-[11px] px-[22px] py-5 mb-4">
    <div class="flex items-center gap-[9px] text-[15px] font-semibold text-ink"><%= mi "speed", size: 19, css: "text-ink-3" %>Rate limits</div>
    <div class="text-[13px] text-mut mt-[3px] mb-[18px]">Per-IP request limits for this project. Leave blank to inherit the workspace defaults
      (saveMissing <%= Setting.current.missing_rate_limit %>/<%= Setting.current.missing_rate_period %>s,
      delivery <%= Setting.current.delivery_rate_limit %>/<%= Setting.current.delivery_rate_period %>s).</div>

    <%= form_with model: @project, local: true do |form| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-[7px]">
          <%= form.label :missing_rate_limit, "saveMissing", class: "text-[12.5px] font-medium text-ink-2" %>
          <div class="relative">
            <%= form.number_field :missing_rate_limit, min: 1, placeholder: "#{Setting.current.missing_rate_limit} (inherited)", class: "text-[14px] pr-[66px]" %>
            <span class="absolute right-[12px] top-1/2 -translate-y-1/2 font-mono text-[11.5px] text-mut pointer-events-none">req/min</span>
          </div>
        </div>
        <div class="flex flex-col gap-[7px]">
          <%= form.label :delivery_rate_limit, "Delivery", class: "text-[12.5px] font-medium text-ink-2" %>
          <div class="relative">
            <%= form.number_field :delivery_rate_limit, min: 1, placeholder: "#{Setting.current.delivery_rate_limit} (inherited)", class: "text-[14px] pr-[66px]" %>
            <span class="absolute right-[12px] top-1/2 -translate-y-1/2 font-mono text-[11.5px] text-mut pointer-events-none">req/min</span>
          </div>
        </div>
      </div>
      <div class="flex justify-end mt-[18px]">
        <%= loading_submit form, "Save rate limits" %>
      </div>
    <% end %>
  </div>

  <%# ---- Danger zone ---- %>
  <div class="border border-danger-border rounded-[11px] px-[22px] py-5 bg-danger-soft">
    <div class="flex items-center gap-[9px] text-[15px] font-semibold text-danger-ink"><%= mi "warning", size: 19 %>Danger zone</div>
    <div class="flex items-center justify-between gap-6 mt-[10px] flex-wrap">
      <div>
        <div class="text-[13.5px] font-semibold text-ink">Delete this project</div>
        <div class="text-[13px] text-ink-3 mt-[3px]">Permanently removes all keys, locales and translations. This cannot be undone.</div>
      </div>
      <span data-controller="modal confirm-input" data-confirm-input-match-value="<%= @project.slug %>">
        <button type="button" class="btn-secondary btn-danger flex-none" data-action="click->modal#open">
          <%= mi "delete", size: 16, css: "mr-[5px]" %>Delete project
        </button>

        <dialog class="modal w-[432px]" data-modal-target="dialog" data-action="click->modal#closeOnBackdrop confirm-input#reset" aria-labelledby="delete-project-title">
          <%= form_with url: project_path(@project), method: :delete do %>
            <div class="p-[22px] pb-0 flex items-start gap-[13px]">
              <div class="w-[38px] h-[38px] rounded-[10px] bg-danger-soft text-danger-ink flex items-center justify-center flex-none"><%= mi "warning", size: 20 %></div>
              <div class="min-w-0 flex-1">
                <h3 id="delete-project-title" class="m-0 text-[16px] font-semibold text-ink">Delete this project</h3>
                <p class="mt-[6px] mb-0 text-[13px] text-mut leading-[1.55]">This permanently removes all keys, locales and translations. This cannot be undone.</p>
              </div>
            </div>
            <div class="px-[22px] pl-[73px] pt-4">
              <label class="block text-[12px] text-mut mb-[7px]">Type the project slug <span class="font-mono text-ink-2"><%= @project.slug %></span> to confirm</label>
              <input type="text" autocomplete="off" autocapitalize="none" spellcheck="false"
                     data-confirm-input-target="input" data-action="input->confirm-input#check"
                     class="w-full font-mono text-[13px]" />
            </div>
            <div class="flex justify-end gap-[9px] p-[22px] pt-5">
              <button type="button" class="btn-secondary" data-action="click->modal#close">Cancel</button>
              <button type="submit" data-confirm-input-target="submit" disabled
                      class="inline-flex items-center justify-center h-[38px] px-[18px] rounded-[6px] bg-danger-ink text-white text-[13px] font-medium hover:bg-[#991b1b] disabled:opacity-50 disabled:cursor-not-allowed">
                Delete project
              </button>
            </div>
          <% end %>
        </dialog>
      </span>
    </div>
  </div>
  </div>
</div>
