<% content_for :title, "Accept invitation" %>

<section class="auth">
  <h1>You're invited to Language Bridge</h1>

  <p><strong><%= @invitation.inviter.email %></strong> invited you to join as <strong><%= @invitation.role %></strong>.</p>

  <%= form_with url: claim_invitation_path(token: @invitation.token), method: :post, local: true do |form| %>
    <%= form.email_field :email, value: @invitation.email, readonly: true %>
    <%= form.submit "Accept and sign in" %>
  <% end %>
</section>
