<%= form_with model: @project, local: true, html: { class: "border border-line rounded-[11px] p-[22px] flex flex-col gap-4" } do |form| %>
  <% if @project.errors.any? %>
    <ul class="text-[13px] text-danger-ink bg-danger-soft border border-danger-border rounded-[9px] px-4 py-3 list-disc list-inside">
      <% @project.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
    </ul>
  <% end %>

  <div class="flex flex-col gap-[7px]">
    <%= form.label :name, class: "text-[12.5px] font-medium text-ink-2" %>
    <%= form.text_field :name, required: true, autofocus: true, placeholder: "My App", class: "text-[14px]" %>
  </div>

  <div class="flex justify-end gap-[9px] pt-1">
    <%= link_to "Cancel", (@project.persisted? ? project_path(@project) : projects_path), class: "btn-secondary" %>
    <%= form.submit class: "btn" %>
  </div>
<% end %>
