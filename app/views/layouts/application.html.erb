<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Language Bridge" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Language Bridge">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bitter:wght@400;500;600;700&family=Raleway:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/iconoir/css/iconoir.css">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="topbar">
      <a href="/" class="brand">
        <%= image_tag "logo.png", alt: "Language Bridge", class: "brand-logo" %>
        <span>language bridge.</span>
      </a>
      <% if signed_in? %>
        <nav>
          <ul>
            <li>
              <%= link_to projects_path, class: "nav-link" do %>
                <i class="iconoir-folder" aria-hidden="true"></i>
                <span>Projects</span>
              <% end %>
            </li>
            <% if current_user.admin? %>
              <li>
                <%= link_to invitations_path, class: "nav-link" do %>
                  <i class="iconoir-mail" aria-hidden="true"></i>
                  <span>Invitations</span>
                <% end %>
              </li>
            <% end %>
            <li>
              <%= button_to sign_out_path,
                    method: :delete,
                    class: "nav-btn",
                    "aria-label": "Sign out" do %>
                <i class="iconoir-log-out" aria-hidden="true"></i>
                <span>Sign out</span>
              <% end %>
            </li>
          </ul>
        </nav>
      <% end %>
    </header>

    <% flash.each do |kind, message| %>
      <div class="flash <%= kind %>"><%= message %></div>
    <% end %>

    <main class="main">
      <%= yield %>
    </main>

    <footer class="footer">
      <span class="brand-mark">language bridge</span>
      <span>open-source translation management</span>
    </footer>
  </body>
</html>
