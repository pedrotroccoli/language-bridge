DB_PASSWORD=postgres

# Mailer (Resend SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Language Bridge <onboarding@resend.dev>
