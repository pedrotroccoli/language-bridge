<details class="locale-item" id="<%= dom_id(locale) %>">
  <summary class="locale-item__summary">
    <i class="iconoir-globe locale-item__icon" aria-hidden="true"></i>
    <span class="locale-item__code"><%= locale.code %></span>
    <span class="locale-item__meta">
      <i class="iconoir-translate" aria-hidden="true"></i>
      <strong><%= locale.translations_count %></strong> translations
    </span>
    <i class="iconoir-nav-arrow-down locale-item__chevron" aria-hidden="true"></i>
  </summary>

  <div class="locale-item__body">
    <% if current_user.admin? %>
      <%= form_with model: [ project, locale ], method: :patch, local: true do |form| %>
        <div class="field-row">
          <div class="field field--grow">
            <%= form.label :code, "Rename" %>
            <%= form.text_field :code, required: true,
                  pattern: "[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*",
                  autocomplete: "off",
                  autocapitalize: "none",
                  spellcheck: "false" %>
          </div>
          <%= form.submit "Save", class: "btn" %>
        </div>
      <% end %>

      <%= button_to project_locale_path(project, locale),
            method: :delete,
            class: "btn btn-secondary btn--danger",
            data: { turbo_confirm: "Delete locale \"#{locale.code}\"? All its translations will be removed." } do %>
        <i class="iconoir-trash" aria-hidden="true"></i>
        Delete locale
      <% end %>
    <% else %>
      <p class="muted">Read-only view.</p>
    <% end %>
  </div>
</details>
