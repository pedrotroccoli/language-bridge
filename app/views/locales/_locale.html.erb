<%# With a namespace → open the editor filtered to this locale. Without one →
    send the user to create their first namespace (nothing to edit yet). %>
<% target = local_assigns[:editor_namespace] ? project_namespace_path(project, editor_namespace, locales: [ locale.code ]) : project_path(project, new: "namespace", anchor: "namespaces") %>
<% row = "flex items-center justify-between px-[18px] py-[15px] border-b border-line-3 last:border-b-0" %>

<% content = capture do %>
  <span class="flex items-center gap-[11px] min-w-0">
    <% if (flag = locale_flag(locale.code)) %>
      <span class="text-[14px] leading-none flex-none w-[22px] text-center" aria-hidden="true"><%= flag %></span>
    <% else %>
      <%= mi "language", size: 18, css: "text-faint" %>
    <% end %>
    <span class="font-mono text-[14px] font-semibold text-ink flex-none"><%= locale.code %></span>
    <% if locale_name(locale.code) %><span class="text-[13.5px] text-ink-3 truncate"><%= locale_name(locale.code) %></span><% end %>
  </span>
  <span class="flex items-center gap-[18px]">
    <span class="font-mono text-[12px] text-ink-3"><span class="text-ink font-semibold"><%= locale.translations_count %></span> translations</span>
    <span class="font-mono text-[12px] text-accent font-semibold w-10 text-right"><%= coverage %>%</span>
    <%= mi "chevron_right", size: 20, css: "text-faint-2" %>
  </span>
<% end %>

<% if target %>
  <%= link_to target, id: dom_id(locale), class: "#{row} no-underline hover:bg-surface-2 transition-colors" do %><%= content %><% end %>
<% else %>
  <div id="<%= dom_id(locale) %>" class="<%= row %>"><%= content %></div>
<% end %>
