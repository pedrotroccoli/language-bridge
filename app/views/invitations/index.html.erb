<% content_for :title, "Invitations" %>

<section class="container stack">
  <header style="display: flex; align-items: center; justify-content: space-between;">
    <h1>Pending invitations</h1>
    <%= link_to "Invite teammate", new_invitation_path, class: "btn", style: "width: auto;" %>
  </header>

  <% if @invitations.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Email</th>
          <th>Role</th>
          <th>Invited</th>
          <th>Expires</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @invitations.each do |invitation| %>
          <tr>
            <td><%= invitation.email %></td>
            <td><%= invitation.role %></td>
            <td><%= time_ago_in_words(invitation.created_at) %> ago</td>
            <td><%= invitation.expires_at.strftime("%b %d, %Y") %></td>
            <td>
              <%= button_to "Revoke",
                    invitation_path(invitation),
                    method: :delete,
                    class: "btn-link",
                    data: { turbo_confirm: "Revoke invitation for #{invitation.email}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="muted">No pending invitations.</p>
  <% end %>
</section>
