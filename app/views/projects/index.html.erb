<% content_for :title, "Projects" %>

<section data-controller="search">
  <% if @projects.any? %>
    <header class="flex items-center justify-between mb-[22px] gap-4 flex-wrap">
      <div class="flex items-baseline gap-3">
        <h1 class="m-0 text-[20px] font-semibold -tracking-[0.02em] text-ink">Projects</h1>
        <span class="font-mono text-[12px] text-faint"><%= format("%02d", @projects.size) %></span>
      </div>

      <div class="flex items-center gap-[10px]">
        <div class="h-9 flex items-center gap-[9px] px-[13px] border border-line rounded-lg text-[13px] w-[250px] focus-within:border-ink transition-colors">
          <%= mi "search", size: 18, css: "text-mut-2" %>
          <input type="search"
                 placeholder="Search projects…"
                 aria-label="Search projects"
                 class="!border-0 !p-0 !shadow-none !rounded-none flex-1 bg-transparent text-[13px] focus:!ring-0"
                 data-search-target="input"
                 data-action="input->search#filter">
          <button type="button" class="text-mut-2 hover:text-ink" data-search-target="clearBtn" data-action="click->search#clear" aria-label="Clear search" hidden>
            <%= mi "close", size: 16 %>
          </button>
        </div>

        <% if current_user.admin? %>
          <%= link_to new_project_path, class: "btn" do %>
            <%= mi "add", size: 17, weight: 400 %>New project
          <% end %>
        <% end %>
      </div>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @projects.each do |project| %>
        <%= render "project", project: project, coverage: @coverage[project.id] %>
      <% end %>
    </div>

    <div class="text-center py-12" data-search-target="empty" hidden>
      <div class="mx-auto w-14 h-14 border border-dashed border-faint-2 rounded-xl flex items-center justify-center text-faint mb-5">
        <%= mi "search", size: 26 %>
      </div>
      <h2 class="text-[19px] font-semibold -tracking-[0.02em] text-ink">No projects found</h2>
      <p class="mt-2 text-[14px] text-mut">Your search for <strong class="text-ink">“<span data-search-target="query"></span>”</strong> returned no results.</p>
      <div class="flex items-center justify-center gap-[10px] mt-5">
        <button type="button" class="btn-secondary" data-action="search#clear">Clear search</button>
        <% if current_user.admin? %>
          <%= link_to new_project_path, class: "btn" do %>
            <%= mi "add", size: 17, weight: 400 %>New project
          <% end %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="py-20 flex flex-col items-center text-center">
      <div class="w-14 h-14 border-[1.5px] border-dashed border-faint-2 rounded-xl flex items-center justify-center text-faint mb-5">
        <%= mi "create_new_folder", size: 28 %>
      </div>
      <h2 class="m-0 text-[19px] font-semibold -tracking-[0.02em] text-ink">No projects yet</h2>
      <p class="mt-2 mb-6 text-[14px] text-mut max-w-[360px] leading-relaxed">Create your first project to start managing keys, locales and translations.</p>
      <% if current_user.admin? %>
        <%= link_to new_project_path, class: "btn h-10 px-[18px] text-[14px]" do %>
          <%= mi "add", size: 17, weight: 400 %>New project
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
